rce":"main.js","original":{"line":73,"column":12}},{"name":"toLowerCase","generated":{"line":55,"column":28},"source":"main.js","original":{"line":73,"column":28}},{"generated":{"line":55,"column":39},"source":"main.js","original":{"line":73,"column":12}},{"name":"key","generated":{"line":55,"column":46},"source":"main.js","original":{"line":73,"column":44}},{"generated":{"line":55,"column":49},"source":"main.js","original":{"line":73,"column":8}},{"generated":{"line":55,"column":51},"source":"main.js","original":{"line":73,"column":49}},{"name":"window","generated":{"line":56,"column":0},"source":"main.js","original":{"line":74,"column":12}},{"name":"open","generated":{"line":56,"column":19},"source":"main.js","original":{"line":74,"column":19}},{"generated":{"line":56,"column":23},"source":"main.js","original":{"line":74,"column":12}},{"name":"hashMap","generated":{"line":56,"column":24},"source":"main.js","original":{"line":74,"column":24}},{"name":"i","generated":{"line":56,"column":32},"source":"main.js","original":{"line":74,"column":32}},{"generated":{"line":56,"column":33},"source":"main.js","original":{"line":74,"column":24}},{"name":"url","generated":{"line":56,"column":35},"source":"main.js","original":{"line":74,"column":35}},{"generated":{"line":56,"column":38},"source":"main.js","original":{"line":74,"column":12}},{"generated":{"line":57,"column":0},"source":"main.js","original":{"line":75,"column":9}},{"generated":{"line":58,"column":0},"source":"main.js","original":{"line":76,"column":5}},{"generated":{"line":59,"column":0},"source":"main.js","original":{"line":77,"column":1}},{"generated":{"line":59,"column":1},"source":"main.js","original":{"line":69,"column":0}}],"sources":{"main.js":"const $siteList = $('.siteList')\r\nconst $lastList = $siteList.find('li.last')\r\nconst x = localStorage.getItem('x')\r\n//将字符串变成对象\r\nconst xObject = JSON.parse(x)\r\nconst hashMap = xObject || [\r\n    { logo: 'A', url: 'https://www.acfun.cn' },\r\n    { logo: 'B', url: 'https://www.bilibili.com' },\r\n];\r\nconst simplifyUrl = (url) => { \r\n    return url.replace('https://', '')\r\n        .replace('http://', '')\r\n        .replace('www.', '')\r\n        .replace(/\\/.*/,'');//删除多余内容\r\n}\r\nconst render = () => { \r\n    $siteList.find('li:not(.last)').remove();\r\n    hashMap.forEach((node, index) => {\r\n        const $li = $(`\r\n        <li>\r\n            <div class=\"site\">\r\n                <div class=\"loge\">${node.logo}</div>\r\n                <div class=\"link\">${simplifyUrl(node.url)}</div>\r\n                <div class=\"close\">\r\n                    <svg  class=\"icon-close\"fill=\"none\" height=\"22\" viewBox=\"0 0 24 24\" width=\"22\" xmlns=\"http://www.w3.org/2000/svg\">\r\n                        <path d=\"M6.2253 4.81108C5.83477 4.42056 5.20161 4.42056 4.81108 4.81108C4.42056 5.20161 4.42056 5.83477 4.81108 6.2253L10.5858 12L4.81114 17.7747C4.42062 18.1652 4.42062 18.7984 4.81114 19.1889C5.20167 19.5794 5.83483 19.5794 6.22535 19.1889L12 13.4142L17.7747 19.1889C18.1652 19.5794 18.7984 19.5794 19.1889 19.1889C19.5794 18.7984 19.5794 18.1652 19.1889 17.7747L13.4142 12L19.189 6.2253C19.5795 5.83477 19.5795 5.20161 19.189 4.81108C18.7985 4.42056 18.1653 4.42056 17.7748 4.81108L12 10.5858L6.2253 4.81108Z\" fill=\"currentColor\"/>\r\n                    </svg>\r\n                </div>\r\n            </div>\r\n        </li>\r\n        `).insertBefore($lastList)\r\n        $li.on('click', () => {\r\n           window.open(node.url)//代替了a标签的作用\r\n        });\r\n        $li.on('click', '.close', (e) => {\r\n            e.stopPropagation() //阻止冒泡\r\n            hashMap.splice(index, 1) //实现删除功能\r\n            render()\r\n        });\r\n    });\r\n}\r\n//增加之前需要渲染hashMap\r\nrender();\r\n\r\n$('.addButton').on('click', () => {\r\n    let url = window.prompt(\"请输入网址：\")\r\n    console.log(url);\r\n    if (url.indexOf('http') !== 0) {\r\n        url = 'https://' + url\r\n    }\r\n    console.log(url);\r\n    \r\n    hashMap.push({\r\n        logo: simplifyUrl(url)[0],\r\n        url: url\r\n    });\r\n//添加之后重新渲染\r\n    render();\r\n    \r\n});\r\n//当用户离开页面，数据会保存，不会丢失\r\nwindow.onbeforeunload = () => { \r\n    //console.log('页面要关闭了');\r\n    //把对象变成字符串\r\n    const string = JSON.stringify(hashMap);\r\n    //在本地存储里，设置一个x，他的值是string\r\n    localStorage.setItem('x', string);\r\n}\r\n$(document).on('keypress', (e) => { \r\n   // const key = e.key;\r\n    const { key } = e\r\n    for (let i = 0; i < hashMap.length; i++) { \r\n        if (hashMap[i].logo.toLowerCase()===key) { \r\n            window.open(hashMap[i].url)\r\n        }  \r\n    } \r\n})\r\n\r\n"},"lineCount":null}},"hash":"3968ca024d0e09ef994afcf137bcf970","cacheData":{"env":{}}}